# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/multiagent_db
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/multiagent_db

# OpenAI (optional - used for smarter intent/script generation)
OPENAI_API_KEY=your_openai_api_key_here

# Embedding model (local, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Vector search
TOP_K_RESULTS=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

PORT=5000
CORS_ORIGIN=http://localhost:3000

# Groq LLM – get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Embeddings & vector store (Python sentence-transformers model name)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
COLLECTION_NAME=instaboot_docs
PERSIST_DIRECTORY=./data/chroma
DB_PATH=./data/app.db

TOP_K=3
CHUNK_SIZE=800
CHUNK_OVERLAP=120
